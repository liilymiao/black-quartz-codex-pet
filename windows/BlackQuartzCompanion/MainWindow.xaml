<Window x:Class="BlackQuartzCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Black Quartz Companion"
        Width="192"
        Height="208"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="静止 / Idle" Tag="Idle" Click="StateMenu_Click" />
            <MenuItem Header="致意 / Acknowledge" Tag="Acknowledge" Click="StateMenu_Click" />
            <MenuItem Header="跃迁 / Jump" Tag="Jump" Click="StateMenu_Click" />
            <MenuItem Header="等待 / Waiting" Tag="Waiting" Click="StateMenu_Click" />
            <MenuItem Header="处理中 / Processing" Tag="Processing" Click="StateMenu_Click" />
            <MenuItem Header="审阅完成 / Review" Tag="Review" Click="StateMenu_Click" />
            <MenuItem Header="失败 / Failed" Tag="Failed" Click="StateMenu_Click" />
            <MenuItem Header="环视 / Look around" Tag="LookAround" Click="StateMenu_Click" />
            <Separator />
            <MenuItem x:Name="FollowPointerMenuItem"
                      Header="跟随指针 / Follow pointer"
                      IsCheckable="True"
                      IsChecked="True"
                      Click="FollowPointerMenuItem_Click" />
            <MenuItem x:Name="TopmostMenuItem"
                      Header="始终置顶 / Always on top"
                      IsCheckable="True"
                      IsChecked="True"
                      Click="TopmostMenuItem_Click" />
            <MenuItem Header="大小 / Scale">
                <MenuItem Header="100%" Tag="1" Click="ScaleMenu_Click" />
                <MenuItem Header="125%" Tag="1.25" Click="ScaleMenu_Click" />
                <MenuItem Header="150%" Tag="1.5" Click="ScaleMenu_Click" />
                <MenuItem Header="200%" Tag="2" Click="ScaleMenu_Click" />
            </MenuItem>
            <Separator />
            <MenuItem Header="退出 / Exit" Click="ExitMenu_Click" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Background="Transparent">
        <Image x:Name="SpriteImage"
               Width="192"
               Height="208"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"
               SnapsToDevicePixels="True"
               ToolTip="拖动移动；左键切换工作状态；右键打开菜单。" />
    </Grid>
</Window>
